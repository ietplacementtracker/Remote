<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    Layout for the Daikin IR Remote.

    Design:
    - Dark background (#1A1A2E) simulating a physical remote.
    - Central temperature display in large bold text.
    - Power button at the top, prominently coloured.
    - Temperature ▲/▼ controls flanking the temp display.
    - Mode row: Cool | Dry | Fan
    - Fan speed row: Auto | Low | Medium | High
    - All buttons are large (min 56 dp height) for easy thumb use.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp"
        android:gravity="center_horizontal">

        <!-- ═══════════════════════════════ -->
        <!--          App Title             -->
        <!-- ═══════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DAIKIN REMOTE"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:letterSpacing="0.3"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="24dp" />

        <!-- ═══════════════════════════════ -->
        <!--  Power Status + Power Button   -->
        <!-- ═══════════════════════════════ -->
        <TextView
            android:id="@+id/tvPowerStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.2"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnPower"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:text="⏻"
            android:textSize="28sp"
            android:textColor="@color/white"
            android:backgroundTintList="@color/power_off"
            android:stateListAnimator="@null"
            android:elevation="4dp"
            style="@style/Widget.AppCompat.Button"
            android:layout_marginBottom="36dp" />

        <!-- ═══════════════════════════════ -->
        <!--    Temperature Control Card    -->
        <!-- ═══════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="24dp"
                android:paddingBottom="24dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Temperature DOWN button -->
                <Button
                    android:id="@+id/btnTempDown"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="▼"
                    android:textSize="22sp"
                    android:textColor="@color/white"
                    android:backgroundTintList="@color/temp_button"
                    android:stateListAnimator="@null"
                    style="@style/Widget.AppCompat.Button" />

                <!-- Temperature Display -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvTemperature"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24°C"
                        android:textColor="@color/white"
                        android:textSize="56sp"
                        android:fontFamily="sans-serif-light"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SET TEMP"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.2"
                        android:fontFamily="sans-serif" />

                </LinearLayout>

                <!-- Temperature UP button -->
                <Button
                    android:id="@+id/btnTempUp"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="▲"
                    android:textSize="22sp"
                    android:textColor="@color/white"
                    android:backgroundTintList="@color/temp_button"
                    android:stateListAnimator="@null"
                    style="@style/Widget.AppCompat.Button" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════ -->
        <!--        Mode Selection          -->
        <!-- ═══════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MODE"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.2"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="28dp">

            <Button
                android:id="@+id/btnCool"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="❄ Cool"
                android:textSize="14sp"
                android:backgroundTintList="@color/unselected_button"
                android:textColor="@color/unselected_text"
                android:stateListAnimator="@null"
                style="@style/Widget.AppCompat.Button" />

            <Button
                android:id="@+id/btnDry"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="💧 Dry"
                android:textSize="14sp"
                android:backgroundTintList="@color/unselected_button"
                android:textColor="@color/unselected_text"
                android:stateListAnimator="@null"
                style="@style/Widget.AppCompat.Button" />

            <Button
                android:id="@+id/btnFan"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="🌀 Fan"
                android:textSize="14sp"
                android:backgroundTintList="@color/unselected_button"
                android:textColor="@color/unselected_text"
                android:stateListAnimator="@null"
                style="@style/Widget.AppCompat.Button" />

        </LinearLayout>

        <!-- ═══════════════════════════════ -->
        <!--       Fan Speed Control        -->
        <!-- ═══════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FAN SPEED"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.2"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnFanAuto"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Auto"
                android:textSize="12sp"
                android:backgroundTintList="@color/unselected_button"
                android:textColor="@color/unselected_text"
                android:stateListAnimator="@null"
                style="@style/Widget.AppCompat.Button" />

            <Button
                android:id="@+id/btnFanLow"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Low"
                android:textSize="12sp"
                android:backgroundTintList="@color/unselected_button"
                android:textColor="@color/unselected_text"
                android:stateListAnimator="@null"
                style="@style/Widget.AppCompat.Button" />

            <Button
                android:id="@+id/btnFanMedium"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Med"
                android:textSize="12sp"
                android:backgroundTintList="@color/unselected_button"
                android:textColor="@color/unselected_text"
                android:stateListAnimator="@null"
                style="@style/Widget.AppCompat.Button" />

            <Button
                android:id="@+id/btnFanHigh"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="High"
                android:textSize="12sp"
                android:backgroundTintList="@color/unselected_button"
                android:textColor="@color/unselected_text"
                android:stateListAnimator="@null"
                style="@style/Widget.AppCompat.Button" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
